<%- include('layouts/main') %>

<!-- Status Filter -->
<div class="card border-0 shadow-sm mb-4">
  <div class="card-body py-2">
    <div class="d-flex gap-2 flex-wrap align-items-center">
      <span class="text-muted small me-2">Filter:</span>
      <a href="/queue" class="btn btn-sm <%= currentStatus === 'all' ? 'btn-primary' : 'btn-outline-secondary' %>">
        All (<%= Object.values(statusCounts).reduce((a, b) => a + b, 0) %>)
      </a>
      <a href="/queue?status=pending" class="btn btn-sm <%= currentStatus === 'pending' ? 'btn-warning' : 'btn-outline-warning' %>">
        Pending (<%= statusCounts.pending %>)
      </a>
      <a href="/queue?status=processing" class="btn btn-sm <%= currentStatus === 'processing' ? 'btn-info' : 'btn-outline-info' %>">
        Processing (<%= statusCounts.processing %>)
      </a>
      <a href="/queue?status=sent" class="btn btn-sm <%= currentStatus === 'sent' ? 'btn-success' : 'btn-outline-success' %>">
        Sent (<%= statusCounts.sent %>)
      </a>
      <a href="/queue?status=failed" class="btn btn-sm <%= currentStatus === 'failed' ? 'btn-danger' : 'btn-outline-danger' %>">
        Failed (<%= statusCounts.failed %>)
      </a>
      <a href="/queue?status=cancelled" class="btn btn-sm <%= currentStatus === 'cancelled' ? 'btn-secondary' : 'btn-outline-secondary' %>">
        Cancelled (<%= statusCounts.cancelled %>)
      </a>
    </div>
  </div>
</div>

<!-- Queue Table -->
<div class="card border-0 shadow-sm">
  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="table table-hover mb-0">
        <thead class="table-light">
          <tr>
            <th>#</th>
            <th>To</th>
            <th>Subject</th>
            <th>Status</th>
            <th>Strategy</th>
            <th>Attempts</th>
            <th>Created</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% if (items.length === 0) { %>
            <tr>
              <td colspan="8" class="text-center text-muted py-4">
                <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                No items in queue
              </td>
            </tr>
          <% } else { %>
            <% items.forEach(function(item) { %>
              <tr>
                <td><small class="text-muted">#<%= item.id %></small></td>
                <td class="fw-medium"><%= item.to_address %></td>
                <td><%= item.subject.length > 40 ? item.subject.substring(0, 40) + '...' : item.subject %></td>
                <td>
                  <% if (item.status === 'pending') { %>
                    <span class="badge bg-warning-subtle text-warning">Pending</span>
                  <% } else if (item.status === 'processing') { %>
                    <span class="badge bg-info-subtle text-info">Processing</span>
                  <% } else if (item.status === 'sent') { %>
                    <span class="badge bg-success-subtle text-success">Sent</span>
                  <% } else if (item.status === 'failed') { %>
                    <span class="badge bg-danger-subtle text-danger" title="<%= item.error_message || '' %>">Failed</span>
                  <% } else { %>
                    <span class="badge bg-secondary-subtle text-secondary">Cancelled</span>
                  <% } %>
                </td>
                <td><small><%= item.strategy %></small></td>
                <td><%= item.attempts %>/<%= item.max_attempts %></td>
                <td><small class="text-muted"><%= new Date(item.created_at).toLocaleString() %></small></td>
                <td>
                  <% if (item.status === 'pending' || item.status === 'failed') { %>
                    <form method="POST" action="/queue/<%= item.id %>/cancel" class="d-inline">
                      <button type="submit" class="btn btn-outline-secondary btn-sm" title="Cancel">
                        <i class="bi bi-x"></i>
                      </button>
                    </form>
                  <% } %>
                  <% if (item.status === 'failed') { %>
                    <form method="POST" action="/queue/<%= item.id %>/retry" class="d-inline">
                      <button type="submit" class="btn btn-outline-primary btn-sm" title="Retry">
                        <i class="bi bi-arrow-clockwise"></i>
                      </button>
                    </form>
                  <% } %>
                </td>
              </tr>
            <% }); %>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
  <% if (pages > 1) { %>
    <div class="card-footer bg-white">
      <nav>
        <ul class="pagination pagination-sm justify-content-center mb-0">
          <% for (let i = 1; i <= pages; i++) { %>
            <li class="page-item <%= i === page ? 'active' : '' %>">
              <a class="page-link" href="/queue?page=<%= i %><%= currentStatus !== 'all' ? '&status=' + currentStatus : '' %>"><%= i %></a>
            </li>
          <% } %>
        </ul>
      </nav>
    </div>
  <% } %>
</div>

<%- include('layouts/footer') %>
