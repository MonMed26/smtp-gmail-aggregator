<%- include('layouts/main') %>

<div class="row g-3 mb-4">
  <div class="col-md-3">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-body">
        <div class="d-flex justify-content-between align-items-start">
          <div>
            <p class="text-muted mb-1 small">Sent Today</p>
            <h3 class="fw-bold mb-0"><%= stats.sentToday %></h3>
          </div>
          <div class="bg-success-subtle rounded-3 p-2">
            <i class="bi bi-check-circle text-success fs-4"></i>
          </div>
        </div>
        <div class="mt-2">
          <small class="text-muted"><%= stats.remaining %> remaining of <%= stats.totalCapacity %></small>
          <div class="progress mt-1" style="height: 4px;">
            <div class="progress-bar bg-success" style="width: <%= stats.totalCapacity > 0 ? (stats.sentToday / stats.totalCapacity * 100) : 0 %>%"></div>
          </div>
        </div>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-body">
        <div class="d-flex justify-content-between align-items-start">
          <div>
            <p class="text-muted mb-1 small">Failed Today</p>
            <h3 class="fw-bold mb-0"><%= stats.failedToday %></h3>
          </div>
          <div class="bg-danger-subtle rounded-3 p-2">
            <i class="bi bi-x-circle text-danger fs-4"></i>
          </div>
        </div>
        <div class="mt-2">
          <small class="text-muted">Success rate: <%= stats.successRate %>%</small>
          <div class="progress mt-1" style="height: 4px;">
            <% const barColor = stats.successRate >= 90 ? 'success' : stats.successRate >= 70 ? 'warning' : 'danger'; %>
            <div class="progress-bar bg-<%= barColor %>" style="width: <%= stats.successRate %>%"></div>
          </div>
        </div>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-body">
        <div class="d-flex justify-content-between align-items-start">
          <div>
            <p class="text-muted mb-1 small">Queue</p>
            <h3 class="fw-bold mb-0"><%= stats.queuePending %></h3>
          </div>
          <div class="bg-warning-subtle rounded-3 p-2">
            <i class="bi bi-hourglass-split text-warning fs-4"></i>
          </div>
        </div>
        <div class="mt-2">
          <small class="text-muted"><%= stats.queueProcessing %> processing</small>
        </div>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-body">
        <div class="d-flex justify-content-between align-items-start">
          <div>
            <p class="text-muted mb-1 small">Accounts</p>
            <h3 class="fw-bold mb-0"><%= stats.activeAccounts %></h3>
          </div>
          <div class="bg-primary-subtle rounded-3 p-2">
            <i class="bi bi-people text-primary fs-4"></i>
          </div>
        </div>
        <div class="mt-2">
          <small class="text-muted"><%= stats.totalAccounts %> total, <%= stats.activeAccounts %> active</small>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="row g-3">
  <div class="col-md-8">
    <div class="card border-0 shadow-sm">
      <div class="card-header bg-white border-bottom py-3">
        <h6 class="mb-0 fw-semibold">Daily Send Activity (Last 7 Days)</h6>
      </div>
      <div class="card-body">
        <div class="table-responsive">
          <table class="table table-sm">
            <thead>
              <tr>
                <th>Date</th>
                <th>Sent</th>
                <th>Failed</th>
                <th>Total</th>
              </tr>
            </thead>
            <tbody>
              <% if (dailyStats.length === 0) { %>
                <tr><td colspan="4" class="text-center text-muted py-3">No data yet</td></tr>
              <% } else { %>
                <% dailyStats.forEach(function(d) { %>
                  <tr>
                    <td><%= d.date %></td>
                    <td><span class="text-success"><%= d.total_sent %></span></td>
                    <td><span class="text-danger"><%= d.total_failed %></span></td>
                    <td><%= d.total_sent + d.total_failed %></td>
                  </tr>
                <% }); %>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
  <div class="col-md-4">
    <div class="card border-0 shadow-sm">
      <div class="card-header bg-white border-bottom py-3">
        <h6 class="mb-0 fw-semibold">Quick Actions</h6>
      </div>
      <div class="card-body d-grid gap-2">
        <a href="/send" class="btn btn-primary">
          <i class="bi bi-send me-1"></i> Send Email
        </a>
        <a href="/accounts" class="btn btn-outline-primary">
          <i class="bi bi-plus-circle me-1"></i> Add Account
        </a>
        <a href="/queue" class="btn btn-outline-secondary">
          <i class="bi bi-list-task me-1"></i> View Queue
        </a>
        <a href="/logs" class="btn btn-outline-secondary">
          <i class="bi bi-journal-text me-1"></i> View Logs
        </a>
      </div>
    </div>
  </div>
</div>

<%- include('layouts/footer') %>
