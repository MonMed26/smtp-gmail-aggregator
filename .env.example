# Server
PORT=3000
NODE_ENV=development

# Database
DB_PATH=./data/aggregator.db

# Encryption (32-byte hex key - generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
ENCRYPTION_KEY=

# API Authentication
API_KEY=

# Dashboard Auth
DASHBOARD_USER=admin
DASHBOARD_PASS=

# Session Secret
SESSION_SECRET=

# Queue Worker
QUEUE_POLL_INTERVAL=5000
QUEUE_BATCH_SIZE=10

# Default Load Balancing Strategy (round-robin | least-used | random)
DEFAULT_STRATEGY=round-robin

# SMTP Settings (outgoing to Gmail)
SMTP_TIMEOUT=10000
SMTP_POOL_SIZE=5

# SMTP Server (incoming - acts as an SMTP relay)
# Apps can connect to this SMTP server and send emails through the aggregator
SMTP_SERVER_ENABLED=true
SMTP_SERVER_PORT=587
SMTP_SERVER_USER=aggregator
SMTP_SERVER_PASS=
# Mode: "direct" = send immediately, "queue" = add to queue for background processing
SMTP_SERVER_MODE=direct
