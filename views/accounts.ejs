<%- include('layouts/main') %>

<% if (typeof error !== 'undefined' && error) { %>
  <div class="alert alert-danger alert-dismissible fade show">
    <i class="bi bi-exclamation-circle me-1"></i> <%= error %>
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
  </div>
<% } %>

<% if (typeof testResult !== 'undefined' && testResult) { %>
  <div class="alert alert-<%= testResult.success ? 'success' : 'danger' %> alert-dismissible fade show">
    <i class="bi bi-<%= testResult.success ? 'check-circle' : 'x-circle' %> me-1"></i>
    SMTP Test: <%= testResult.success ? 'Connection successful!' : 'Failed - ' + testResult.error %>
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
  </div>
<% } %>

<!-- Add Account Form -->
<div class="card border-0 shadow-sm mb-4">
  <div class="card-header bg-white border-bottom py-3">
    <h6 class="mb-0 fw-semibold"><i class="bi bi-plus-circle me-1"></i> Add Gmail Account</h6>
  </div>
  <div class="card-body">
    <form method="POST" action="/accounts">
      <div class="row g-3">
        <div class="col-md-4">
          <label for="email" class="form-label">Gmail Address</label>
          <input type="email" class="form-control" id="email" name="email" placeholder="user@gmail.com" required>
        </div>
        <div class="col-md-3">
          <label for="app_password" class="form-label">App Password</label>
          <input type="password" class="form-control" id="app_password" name="app_password" placeholder="xxxx xxxx xxxx xxxx" required>
        </div>
        <div class="col-md-2">
          <label for="display_name" class="form-label">Display Name</label>
          <input type="text" class="form-control" id="display_name" name="display_name" placeholder="Optional">
        </div>
        <div class="col-md-2">
          <label for="daily_limit" class="form-label">Daily Limit</label>
          <input type="number" class="form-control" id="daily_limit" name="daily_limit" value="500" min="1">
        </div>
        <div class="col-md-1 d-flex align-items-end">
          <button type="submit" class="btn btn-primary w-100">Add</button>
        </div>
      </div>
    </form>
  </div>
</div>

<!-- Accounts Table -->
<div class="card border-0 shadow-sm">
  <div class="card-header bg-white border-bottom py-3 d-flex justify-content-between align-items-center">
    <h6 class="mb-0 fw-semibold"><i class="bi bi-people me-1"></i> Gmail Accounts (<%= accounts.length %>)</h6>
  </div>
  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="table table-hover mb-0">
        <thead class="table-light">
          <tr>
            <th>Email</th>
            <th>Display Name</th>
            <th>Status</th>
            <th>Daily Limit</th>
            <th>Sent Today</th>
            <th>Remaining</th>
            <th>Last Used</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% if (accounts.length === 0) { %>
            <tr>
              <td colspan="8" class="text-center text-muted py-4">
                <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                No accounts added yet. Add your first Gmail account above.
              </td>
            </tr>
          <% } else { %>
            <% accounts.forEach(function(account) { %>
              <tr>
                <td class="fw-medium"><%= account.email %></td>
                <td><%= account.display_name || '-' %></td>
                <td>
                  <% if (account.is_active) { %>
                    <span class="badge bg-success-subtle text-success">Active</span>
                  <% } else { %>
                    <span class="badge bg-secondary-subtle text-secondary">Disabled</span>
                  <% } %>
                </td>
                <td><%= account.daily_limit %></td>
                <td><%= account.today_sent %></td>
                <td>
                  <% const remaining = Math.max(0, account.daily_limit - account.today_sent); %>
                  <% const pct = account.daily_limit > 0 ? (account.today_sent / account.daily_limit * 100) : 0; %>
                  <span class="<%= pct > 90 ? 'text-danger' : pct > 70 ? 'text-warning' : 'text-success' %>">
                    <%= remaining %>
                  </span>
                </td>
                <td><small class="text-muted"><%= account.last_used_at ? new Date(account.last_used_at).toLocaleString() : 'Never' %></small></td>
                <td>
                  <div class="btn-group btn-group-sm">
                    <form method="POST" action="/accounts/<%= account.id %>/test" class="d-inline">
                      <button type="submit" class="btn btn-outline-info btn-sm" title="Test SMTP">
                        <i class="bi bi-plug"></i>
                      </button>
                    </form>
                    <form method="POST" action="/accounts/<%= account.id %>/toggle" class="d-inline">
                      <button type="submit" class="btn btn-outline-<%= account.is_active ? 'warning' : 'success' %> btn-sm" title="<%= account.is_active ? 'Disable' : 'Enable' %>">
                        <i class="bi bi-<%= account.is_active ? 'pause' : 'play' %>"></i>
                      </button>
                    </form>
                    <form method="POST" action="/accounts/<%= account.id %>/delete" class="d-inline" onsubmit="return confirm('Delete this account?')">
                      <button type="submit" class="btn btn-outline-danger btn-sm" title="Delete">
                        <i class="bi bi-trash"></i>
                      </button>
                    </form>
                  </div>
                </td>
              </tr>
            <% }); %>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<%- include('layouts/footer') %>
